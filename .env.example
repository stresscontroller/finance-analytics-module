# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF

# Storage
BASE_DIR=/opt/portfolio-telegram-analytics
VAR_DIR=/opt/portfolio-telegram-analytics/var
UPLOAD_DIR=/opt/portfolio-telegram-analytics/var/uploads
REPORT_DIR=/opt/portfolio-telegram-analytics/var/reports
CACHE_DIR=/opt/portfolio-telegram-analytics/var/cache

# Database (SQLite default)
DATABASE_URL=sqlite:////opt/portfolio-telegram-analytics/var/app.sqlite3

# Analytics
RISK_FREE_RATE_ANNUAL=0.02
BENCHMARK_SP500=SPY
BENCHMARK_R2000=IWM
HISTORY_MONTHS=3
MAX_UPLOAD_MB=10

# Optional OpenClaw Hooks (for UI visibility)
# OpenClaw webhooks live on the gateway, typically loopback: http://127.0.0.1:18789/hooks
# Enable hooks in OpenClaw config + token (see README).
OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks
OPENCLAW_HOOKS_TOKEN=your_shared_secret
OPENCLAW_HOOKS_AGENTID=hooks
OPENCLAW_HOOKS_DELIVER=false
OPENCLAW_HOOKS_CHANNEL=telegram
# If deliver=true and you want OpenClaw to send to a specific Telegram chat:
OPENCLAW_HOOKS_TO=